              <calculation class='tableau' formula='306' />
            </column>
            <column caption='Enter Month' datatype='integer' datatype-customized='true' name='[Parameter 3623807528333328]' param-domain-type='list' role='measure' type='quantitative' value='2'>
              <calculation class='tableau' formula='2' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1epgpp60yp3vdg1dcuxaa0mr0og7'>
            <column caption='Selected Employee ID' datatype='boolean' name='[Calculation_3623807501996039]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[employee_id] = [Parameters].[Parameter 3623807499624452]' />
            </column>
            <column caption='RAG Status' datatype='string' name='[Calculation_3623807514312713]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [pct_to_target] &gt;= 1.0 THEN &quot;Green&quot;&#10;ELSEIF [pct_to_target] &gt;= 0.8 THEN &quot;Amber&quot;&#10;ELSE &quot;Red&quot;&#10;END' />
            </column>
            <column caption='Pillar Weight' datatype='real' name='[Calculation_3623807514517515]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [pillar_name]&#10;WHEN &quot;Lending&quot; THEN 0.35&#10;WHEN &quot;Investing&quot; THEN 0.35&#10;WHEN &quot;Banking&quot; THEN 0.15&#10;WHEN &quot;LEI&quot; THEN 0.15&#10;END' />
            </column>
            <column caption='Actual Value' datatype='real' name='[Calculation_3623807517364236]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='CASE [pillar_name]&#10;WHEN &quot;Lending&quot; THEN [lending_actual]&#10;WHEN &quot;Investing&quot; THEN [investing_actual]&#10;WHEN &quot;Banking&quot; THEN [banking_units_actual]&#10;WHEN &quot;LEI&quot; THEN [lei_actual]&#10;END' />
            </column>
            <column caption='Target Value' datatype='real' name='[Calculation_3623807520337935]' role='measure' type='quantitative'>
